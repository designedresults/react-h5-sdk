{
 "name": "@designedresults/react-h5-sdk",
 "version": "2.0.0",
 "description": "React utilities for M3 H5 SDK apps",
 "type": "module",
 "main": "lib/index.js",
 "types": "lib/index.d.ts",
 "files": [
  "lib/**/*"
 ],
 "publishConfig": {
  "name": "@designedresults/react-h5-sdk"
 },
 "homepage": "https://github.com/designedresults/react-h5-sdk#readme",
 "repository": {
  "type": "git",
  "url": "git+https://github.com/designedresults/react-h5-sdk.git"
 },
 "license": "MIT",
 "author": {
  "name": "John Hagler",
  "email": "john@designedresults.co",
  "url": "https://designedresults.co"
 },
 "scripts": {
  "build:dev": "rm -rf ./lib/ && tsc --project tsconfig.json --watch",
  "build": "rm -rf ./lib/ && tsc --project tsconfig.build.json",
  "publish:patch": "npm version patch && npm publish",
  "dev": "concurrently \"pnpm proxy\" \"vite\"",
  "proxy": "ionapi-proxy-server --file Rosboro.ionapi",
  "clean": "rm -rf ./lib/",
  "test:watch": "jest --watch",
  "test": "jest --coverage",
  "typecheck": "tsc --noEmit",
  "lint": "eslint ."
 },
 "dependencies": {
  "@designedresults/m3api-h5-sdk": "^3.3.3",
  "@emotion/react": "^11.14.0",
  "@emotion/styled": "^11.14.1",
  "@mui/icons-material": "^9.0.0",
  "@mui/material": "^9.0.0",
  "@mui/x-data-grid": "^9.0.4",
  "@mui/x-date-pickers": "^9.0.4",
  "@mui/x-license": "^9.0.4",
  "@reduxjs/toolkit": "^2.11.2",
  "@uidotdev/usehooks": "^2.4.1",
  "dayjs": "^1.11.20",
  "numeral": "^2.0.6",
  "observable-hooks": "^4.2.4",
  "react": "^19.2.5",
  "react-dom": "^19.2.5",
  "react-dropzone": "^15.0.0",
  "react-error-boundary": "^6.1.1",
  "react-hook-form-mui": "^9.0.1",
  "react-redux": "^9.2.0",
  "react-router-dom": "^7.14.2"
 },
 "devDependencies": {
  "@eslint/js": "^10.0.1",
  "@types/node": "^25.6.0",
  "@types/react": "^19.2.14",
  "@types/react-dom": "^19.2.3",
  "@vitejs/plugin-react": "^6.0.1",
  "eslint": "^10.3.0",
  "eslint-plugin-react-hooks": "^7.1.1",
  "eslint-plugin-react-refresh": "^0.5.2",
  "globals": "^17.6.0",
  "typescript": "~6.0.3",
  "typescript-eslint": "^8.59.1",
  "vite": "^8.0.10"
 }
}
